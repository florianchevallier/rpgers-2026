# Application
RPGERS_API_URL=https://rpgers.gobelin-tech.online
APP_BASE_URL=http://localhost:3000
SESSION_SECRET=replace-with-at-least-32-random-characters
DATABASE_URL=file:./dev.db

# Compte technique utilisé uniquement par le poller de nouvelles tablées
RPGERS_BOT_PSEUDO=
RPGERS_BOT_PASSWORD=

# Slack (bot sortant : SLACK_SIGNING_SECRET inutile)
SLACK_BOT_TOKEN=
SLACK_CHANNEL_ID=
SLACK_CRON_SECRET=replace-with-at-least-32-random-characters

# Enrichissement optionnel. Sans clé, le message déterministe est envoyé.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash
GEMINI_RECOMMENDER_MODEL=gemini-3.6-flash
PERPLEXITY_API_KEY=
PERPLEXITY_MODEL=sonar-pro
GAME_RESEARCH_CACHE_DAYS=30
